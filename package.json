{
  "name": "trmeric-testing",
  "version": "2.0.0",
  "description": "Trmeric Platform Testing Framework — Production Pre-Deployment Testing Suite",
  "scripts": {
    "test": "npx playwright test --project=platform",
    "test:smoke": "npx playwright test --project=smoke",
    "test:platform": "npx playwright test --project=platform",
    "test:stories": "npx playwright test --project=user-stories",
    "test:visual": "npx playwright test --project=visual",
    "test:visual:update": "npx playwright test --project=visual --update-snapshots",
    "test:all": "npx playwright test --project=smoke --project=platform --project=visual --project=user-stories",
    "test:ui": "npx playwright test --project=platform --ui",
    "test:report": "npx playwright show-report reports/%TRMERIC_ENV%",
    "test:headed": "npx playwright test --project=platform --headed",
    "test:debug": "npx playwright test --project=platform --debug",
    "test:a11y": "npx playwright test --project=a11y",
    "test:tablet": "npx playwright test --project=tablet",
    "test:mobile": "npx playwright test --project=mobile",
    "test:responsive": "npx playwright test --project=tablet --project=mobile",
    "test:full": "npx playwright test --project=smoke --project=platform --project=visual --project=user-stories --project=a11y",

    "deploy:check": "npx playwright test --project=deploy-gate",
    "deploy:check:ci": "set CI=true&& npx playwright test --project=deploy-gate",
    "deploy:report": "npx playwright show-report reports/dev",
    "deploy:verdict": "node -e \"const r=require('./reports/'+( process.env.TRMERIC_ENV||'dev')+'-deploy-verdict.json'); console.log(r.verdict, r.results.passRate+'%%'); process.exit(r.deployable?0:1)\"",

    "demo": "npx playwright test --project=demo --headed",
    "demo:record": "npx playwright test --project=demo --headed --video on",

    "dev": "set TRMERIC_ENV=dev&& npx playwright test --project=smoke --project=platform",
    "dev:smoke": "set TRMERIC_ENV=dev&& npx playwright test --project=smoke",
    "dev:full": "set TRMERIC_ENV=dev&& npx playwright test --project=smoke --project=platform --project=user-stories",
    "dev:gate": "set TRMERIC_ENV=dev&& npx playwright test --project=deploy-gate",
    "dev:ui": "set TRMERIC_ENV=dev&& npx playwright test --project=platform --ui",
    "dev:report": "npx playwright show-report reports/dev",

    "qa": "set TRMERIC_ENV=qa&& npx playwright test --project=smoke --project=platform",
    "qa:smoke": "set TRMERIC_ENV=qa&& npx playwright test --project=smoke",
    "qa:full": "set TRMERIC_ENV=qa&& npx playwright test --project=smoke --project=platform --project=user-stories",
    "qa:gate": "set TRMERIC_ENV=qa&& npx playwright test --project=deploy-gate",
    "qa:report": "npx playwright show-report reports/qa",

    "eu": "set TRMERIC_ENV=eu&& npx playwright test --project=smoke --project=platform",
    "eu:smoke": "set TRMERIC_ENV=eu&& npx playwright test --project=smoke",
    "eu:gate": "set TRMERIC_ENV=eu&& npx playwright test --project=deploy-gate",
    "eu:report": "npx playwright show-report reports/eu",

    "prod:smoke": "set TRMERIC_ENV=prod&& npx playwright test --project=smoke",
    "prod:report": "npx playwright show-report reports/prod",

    "story:new": "echo Copy tests/user-stories/_TEMPLATE.spec.ts and rename for your VE ticket"
  },
  "keywords": [
    "trmeric",
    "e2e",
    "playwright",
    "testing",
    "deploy-gate",
    "pre-deployment"
  ],
  "author": "Trmeric Engineering",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "dotenv": "^17.4.2"
  }
}
