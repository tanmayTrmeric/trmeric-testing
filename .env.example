# ═══════════════════════════════════════════════════════════════
# Trmeric Testing — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env:  copy .env.example .env

# ── Instance ─────────────────────────────────────────────────
# Which instance to test: dev | qa | eu | prod
TRMERIC_ENV=dev

# ── URLs (optional — overrides instance defaults) ────────────
# TRMERIC_FRONTEND_URL=http://localhost:5173
# TRMERIC_BASE_URL=https://trmeric-strong.trmeric.com

# ── Auth Mode 1: Token (instant, skips login UI) ────────────
# Paste your JWT from browser DevTools → Application → Cookies
# If set, all browser login is skipped entirely
TRMERIC_AUTH_TOKEN=

# ── Auth Mode 2: Browser Login (email → password → MFA) ─────
# Used when TRMERIC_AUTH_TOKEN is empty

# Role 1: Resource Manager
TRMERIC_RM_EMAIL=resourcemanagervespa+RM8@gmail.com
TRMERIC_RM_PASSWORD=your_password_here

# Role 2: Demand Owner
TRMERIC_DO_EMAIL=amruta.vespa1+DO8@gmail.com
TRMERIC_DO_PASSWORD=your_password_here

# Role 3: Portfolio Leader
TRMERIC_PL_EMAIL=portfolioleadervespa+PL8@gmail.com
TRMERIC_PL_PASSWORD=your_password_here

# Role 4: Solution Manager
TRMERIC_SM_EMAIL=solutionmanagervespa+SM8@gmail.com
TRMERIC_SM_PASSWORD=your_password_here

# Role 5: Demand Requestor
TRMERIC_DR_EMAIL=resourcevespa+R8@gmail.com
TRMERIC_DR_PASSWORD=your_password_here

# ── Legacy (backward compatible) ────────────────────────────
# These still work if you don't set the role-specific ones above
TRMERIC_TEST_EMAIL=tanmay+bhp_rm1@trmeric.com
TRMERIC_TEST_PASSWORD=Trmeric@2004
